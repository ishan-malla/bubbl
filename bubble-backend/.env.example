PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/bubble

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Gmail SMTP (recommended: App Password)
# Option A (simplest): Gmail service
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM="Bubble <your_email@gmail.com>"

# Option B: custom SMTP (leave empty if using Gmail service above)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public backend URL used in email links (fallback)
BACKEND_PUBLIC_URL=http://localhost:4000

# Optional: multiple base URLs for email links (comma-separated).
# Example:
# BACKEND_PUBLIC_URLS=http://localhost:4000,http://192.168.1.50:4000,https://your-port-forward-url
BACKEND_PUBLIC_URLS=

# Optional: deep link used after verification
APP_DEEPLINK_URL=Bubble://

# Optional: show logo in emails/pages
# - Put your logo at `bubble-backend/public/logo.png`
# - In email previews, it will be embedded as base64 automatically
# - In real emails, most clients load images from a URL (not from your laptop),
#   so keep BACKEND_PUBLIC_URL public if you want recipients to see the logo.
EMAIL_SHOW_LOGO=true
EMAIL_LOGO_URL=
